   "source": [
    "## 7. Merge Datasets on SA2 Code\n",
    "\n",
    "Now we join SEIFA and DSS payment data on the SA2 code — \n",
    "the common geographic key across all ABS/DSS datasets.\n",
    "\n",
    "This produces our **master analytical dataset** that later phases \n",
    "will use for EDA, feature engineering, and modelling."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a470748c-b700-47cf-b008-d9018081571e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check both clean files exist before attempting merge\n",
    "\n",
    "seifa_path = os.path.join(PROCESSED_DIR, \"seifa_clean.csv\")\n",
    "dss_path   = os.path.join(PROCESSED_DIR, \"dss_payments_clean.csv\")\n",
    "\n",
    "files_ready = True\n",
    "\n",
    "for label, path in [(\"SEIFA clean\", seifa_path), (\"DSS clean\", dss_path)]:\n",
    "    if os.path.exists(path):\n",
    "        print(f\"  [✓] {label} found — {path}\")\n",
    "    else:\n",
    "        print(f\"  [✗] {label} NOT found — complete earlier steps first\")\n",
    "        files_ready = False\n",
    "\n",
    "print()\n",
    "if files_ready:\n",
    "    print(\"  Both files present — ready to merge\")\n",
    "else:\n",
    "    print(\"  One or more files missing — scroll up and complete download steps\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dcb61461-603e-4937-b4c1-026c05482186",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge SEIFA + DSS on sa2_name\n",
    "# DSS uses a 5-digit SA2 code which does NOT match the 9-digit ABS SA2 code in SEIFA\n",
    "# Safe join key is sa2_name (normalised to lowercase + stripped)\n",
    "if files_ready:\n",
    "    df_seifa_m = pd.read_csv(seifa_path)\n",
    "    df_dss_m   = pd.read_csv(dss_path)\n",
    "\n",
    "    # Normalise name for matching\n",
    "    df_seifa_m[\"_join_key\"] = df_seifa_m[\"sa2_name\"].str.strip().str.lower()\n",
    "    df_dss_m[\"_join_key\"]   = df_dss_m[\"sa2_name\"].str.strip().str.lower()\n",
    "\n",
    "    df_master = pd.merge(\n",
    "        df_seifa_m,\n",
    "        df_dss_m.drop(columns=[\"sa2_name\"]),  # drop to avoid duplicate column\n",
    "        on=\"_join_key\",\n",
    "        how=\"left\"\n",
    "    )\n",
    "\n",
    "    # Drop helper key\n",
    "    df_master = df_master.drop(columns=[\"_join_key\"])\n",
    "\n",
    "    matched = df_master[\"jobseeker_payment\"].notna().sum()\n",
    "    unmatched = df_master[\"jobseeker_payment\"].isna().sum()\n",
    "\n",
    "    print(f\"Merge complete!\")\n",
    "    print(f\"  SEIFA rows          : {len(df_seifa_m):,}\")\n",
    "    print(f\"  DSS rows            : {len(df_dss_m):,}\")\n",
    "    print(f\"  Master rows         : {len(df_master):,}\")\n",
    "    print(f\"  Matched (with DSS)  : {matched:,}\")\n",
    "    print(f\"  Unmatched (no DSS)  : {unmatched:,}\")\n",
    "    print(f\"  Master columns      : {df_master.shape[1]}\")\n",
    "    print()\n",
    "    df_master.head(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e21cd201-5924-41cf-9994-d93d94d76677",
   "metadata": {},
   "outputs": [],
   "source": [
    "if files_ready and \"df_master\" in dir():\n",
    "\n",
    "    # Clean-up\n",
    "    # 1. Drop copyright footer row (crept in from Excel file)\n",
    "    # 2. Drop blank SEIFA row\n",
    "    # 3. Drop redundant DSS sa2 code column\n",
    "    df_master = df_master[~df_master['sa2_code'].astype(str).str.contains('©', na=False)]\n",
    "    df_master = df_master.dropna(subset=[\"sa2_name\", \"irsd_score\"])\n",
    "    df_master = df_master.drop(columns=[\"sa2\"])\n",
    "    df_master = df_master.reset_index(drop=True)\n",
    "\n",
    "    # Save\n",
    "    master_out = os.path.join(PROCESSED_DIR, \"master_dataset.csv\")\n",
    "    df_master.to_csv(master_out, index=False)\n",
    "    print(f\"[✓] Master dataset saved → {master_out}\")\n",
    "    print(f\"    Final shape: {df_master.shape}\")\n",
    "    print()\n",
    "\n",
    "    # Remaining nulls summary\n",
    "    print(\"Remaining nulls:\")\n",
    "    missing = df_master.isnull().sum()\n",
    "    missing = missing[missing > 0]\n",
    "    if len(missing) == 0:\n",
    "        print(\"  None\")\n",
    "    else:\n",
    "        for col, n in missing.items():\n",
    "            print(f\"  {col:<45} {n:>4} nulls\")\n",
    "    print()\n",
    "\n",
    "    # Column list\n",
    "    print(\"Columns in master dataset:\")\n",
    "    for col in df_master.columns:\n",
    "        print(f\"  {col}\")"
   ]
