    "    df_pop_raw = df_pop_raw.dropna(how=\"all\").dropna(axis=1, how=\"all\")\n",
    "\n",
    "    # Row 0 contains the actual geo column names — extract them\n",
    "    geo_names = df_pop_raw.iloc[0, :10].tolist()   # S/T code, S/T name ... SA2 name\n",
    "\n",
    "    # Build flat column list\n",
    "    cols = geo_names.copy()                         # first 10 geo cols\n",
    "    for top, bot in df_pop_raw.columns[10:]:        # remaining are year population cols\n",
    "        cols.append(f\"pop_{int(bot)}\")              # e.g. pop_2022\n",
    "\n",
    "    # Drop the name row and assign clean columns\n",
    "    df_pop_raw = df_pop_raw.iloc[1:].reset_index(drop=True)\n",
    "    df_pop_raw.columns = cols\n",
    "\n",
    "    # Standardise to snake_case\n",
    "    df_pop_raw.columns = (\n",
    "        pd.Index(cols)\n",
    "        .str.strip()\n",
    "        .str.lower()\n",
    "        .str.replace(\" \", \"_\", regex=False)\n",
    "        .str.replace(\"/\", \"_\", regex=False)\n",
    "    )\n",
    "\n",
    "    # Keep only SA2 identifiers + 2022 population\n",
    "    df_pop = df_pop_raw[['s_t_code', 's_t_name', 'sa2_code', 'sa2_name', 'pop_2022']].copy()\n",
    "    df_pop = df_pop.rename(columns={\n",
    "        's_t_code': 'state_code',\n",
    "        's_t_name': 'state_name',\n",
    "    })\n",
    "\n",
    "    print(f\"Population data loaded: {df_pop.shape[0]:,} rows x {df_pop.shape[1]} columns\")\n",
    "    print()\n",
    "    df_pop.head(3)\n",
    "else:\n",
    "    print(\"File not found — complete download step first\")"
   ]
  },
