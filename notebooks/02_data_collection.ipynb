   "source": [
    "## 2. Download Helper Function\n",
    "\n",
    "Rather than downloading files manually, we write a reusable function that:\n",
    "- Checks if the file already exists before downloading (avoids re-downloading)\n",
    "- Shows file size after download\n",
    "- Handles network errors gracefully\n",
    "\n",
    "This is a standard pattern in professional data pipelines."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "75e32f96-0db5-447c-a93a-1a112373376c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def download_file(url, destination, description=\"\"):\n",
    "    \"\"\"\n",
    "    Download a file from a URL to a local destination path.\n",
    "    Skips download if the file already exists.\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    url         : str  — the download URL\n",
    "    destination : str  — full local file path to save to\n",
    "    description : str  — human-readable label for progress output\n",
    "    \n",
    "    Returns\n",
    "    -------\n",
    "    bool — True if file is available (downloaded or already existed)\n",
    "    \"\"\"\n",
    "    if os.path.exists(destination):\n",
    "        size_mb = os.path.getsize(destination) / (1024 * 1024)\n",
    "        print(f\"  [✓] Already exists — {description} ({size_mb:.1f} MB)\")\n",
    "        return True\n",
    "\n",
    "    print(f\"  [↓] Downloading — {description} ...\")\n",
    "    \n",
    "    try:\n",
    "        # stream=True downloads in chunks — important for large files\n",
    "        # so we don't load the entire file into RAM before saving\n",
    "        response = requests.get(url, stream=True, timeout=60)\n",
    "        response.raise_for_status()   # raises an error if HTTP 4xx/5xx\n",
    "        \n",
    "        with open(destination, \"wb\") as f:\n",
    "            for chunk in response.iter_content(chunk_size=8192):\n",
    "                f.write(chunk)\n",
    "        \n",
    "        size_mb = os.path.getsize(destination) / (1024 * 1024)\n",
    "        print(f\"  [✓] Saved to {destination} ({size_mb:.1f} MB)\")\n",
    "        return True\n",
    "\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"  [✗] Download failed: {e}\")\n",
    "        print(f\"       Please download manually from: {url}\")\n",
    "        return False\n",
    "\n",
    "\n",
    "print(\"download_file() function defined and ready\")"
   ]
  },
